# Copy to .env and edit locally. Do not commit .env.

INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=home
INFLUXDB_BUCKET=homeassistant
INFLUXDB_TOKEN=put-your-read-only-token-here

# Optional: use a mounted token file instead of INFLUXDB_TOKEN.
# INFLUXDB_TOKEN_FILE=/run/secrets/influxdb_token

INFLUXDB_MCP_SETTINGS=/app/settings.yaml
MCP_ALLOW_RAW_FLUX=false
MCP_MAX_RECORDS=1000
MCP_MAX_QUERY_CHARS=10000
